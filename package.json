{
  "name": "dcbot-bitores-mendez",
  "version": "1.0.0",
  "description": "A modular Discord bot built with discord.js and ES6 modules",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "preinstall": "node -e \"process.env.YOUTUBE_DL_SKIP_PYTHON_CHECK='1'\"",
    "start": "node --dns-result-order=ipv4first src/index.js",
    "dev": "node --watch src/index.js"
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js"
  ],
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.4",
    "opusscript": "^0.1.1",
    "play-dl": "^1.9.7",
    "youtube-dl-exec": "^3.1.7"
  }
}
